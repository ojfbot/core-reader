{
  "buildCommand": "pnpm --filter @core-reader/api build && pnpm --filter @core-reader/browser-app build",
  "outputDirectory": "packages/browser-app/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "functions": {
    "api/[...slug].js": {
      "includeFiles": "decisions/**"
    }
  },
  "rewrites": [
    { "source": "/((?!assets/|api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://frame.jim.software" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
