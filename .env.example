# core-reader API (port 3016)
CORE_REPO_PATH=/path/to/ojfbot/core
PORT=3016
CORS_ORIGIN=http://localhost:4000

# GitHub PAT — required on Vercel (no local core checkout available).
# Fine-grained PAT: Contents:read on ojfbot/core only.
# On Vercel: set as encrypted env var via Vercel dashboard or API.
# Locally: only needed if testing the GitHub data path (CORE_REPO_PATH takes priority).
GITHUB_TOKEN=github_pat_...
GITHUB_CORE_REPO=ojfbot/core

# core-reader browser-app (port 3015)
VITE_CORE_READER_API_URL=http://localhost:3016
